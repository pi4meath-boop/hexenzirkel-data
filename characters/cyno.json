    "team_conditional_modifiers_json": [
      {
        "conditionKey": "c1TogetherWeRiseEM",
        "source": "avatar_10000071",
        "gating": { "constellationMin": 1 },
        "description": "C1 Radiance: Stellar-Conduct — while Cyno is in Pactsworn Pathclearer he gains Together We Rise (+200 Elemental Mastery); switching off him passes it to the incoming character for the remaining duration. Modeled as a party buff so it applies whether Cyno is the scored character or a support.",
