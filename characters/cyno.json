    "self_modifiers_json": {},
    "self_conditional_modifiers_json": [
      {
        "conditionKey": "a1JudicationDmgBonus",
        "source": "avatar_10000071",
        "description": "A1 Featherfall Judgment: when Judication triggers (Endseer stance + Elemental Skill cast while in Pactsworn Pathclearer), Secret Rite: Chasmic Soulfarer/Mortuary Rite DMG is increased by 35%. Note: this shares the skill_dmg_ tag with the base Duststalker Bolt hit, so enabling it also (slightly incorrectly) buffs that hit too — the Starsame (Radiance) bolt is unaffected since it isn't tagged skill_dmg_.",
        "states": [{ "value": "on", "modifiers": { "skill_dmg_": 0.35 } }]
      },
      {
        "conditionKey": "afterBurstEleMas",
        "source": "avatar_10000071",
        "description": "A4 Authority Over the Nine Bows: while transformed into Pactsworn Pathclearer, Cyno gains 100 Elemental Mastery. (2026-07 audit: was missing entirely -- only the A4 EM-scaled DMG-increase ratios for Duststalker Bolt/Starsame/Pathclearer Normal ATK were modeled, not this separate flat EM grant. Confirmed against GO's dm.burst.eleMas = 100, gated by condAfterBurst / Pathclearer state.)",
        "states": [{ "value": "on", "modifiers": { "eleMas": 100 } }]
      },
      {
        "conditionKey": "c2CeremonyElectroDmg",
        "source": "avatar_10000071",
        "gating": { "constellationMin": 2 },
        "description": "C2 Ceremony: Homecoming of Spirits — Cyno's Normal Attack hits increase his own Electro DMG Bonus by 10% for 4s, stacking up to 5 times (max 50%).",
        "states": [
          { "value": "0", "modifiers": {} },
          { "value": "1", "modifiers": { "electro_dmg_": 0.1 } },
          { "value": "2", "modifiers": { "electro_dmg_": 0.2 } },
          { "value": "3", "modifiers": { "electro_dmg_": 0.3 } },
          { "value": "4", "modifiers": { "electro_dmg_": 0.4 } },
          { "value": "5", "modifiers": { "electro_dmg_": 0.5 } }
        ]
